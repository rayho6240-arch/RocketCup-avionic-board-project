# ====================================================================
# RocketCup Avionic Board Project - Git Ignore Rules
# ====================================================================

# --- KiCad 核心忽略項目 (自動遞迴忽略所有目錄) ---
*.bak
*.bkp
*_backups/
*.tmp
*.lck
# Footprint 快取
fp-info-cache

# --- KiCad 6/7/8 備份與個人設定檔 ---
# 原理圖自動備份檔
*.kicad_sch-bak
# PCB版自動備份檔
*.kicad_pcb-bak
# 個人視窗設定與配置 (不傳版控以防不同螢幕配置衝突)
*.kicad_prl
# 個人偏好設定
*.kicad_user

# --- 輸出檔案 (通常不進版控，若要放 Gerber 可手動解除) ---
gbers/
plots/
*.net
*.xml
*.csv
*.gbr
*.drl

# --- 作業系統垃圾檔案 ---
# macOS Finder 配置檔 (全局遞迴忽略)
.DS_Store
# Windows 縮圖快取檔
Thumbs.db

# --- 編輯器與開發環境設定 ---
# VS Code 個人設定檔
.vscode/
# JetBrains 編輯器設定
.idea/
# Jupyter Notebook 快取
.ipynb_checkpoints/

# --- AI 代理 session 產物（多代理協作暫存目錄，勿入版控） ---
.agents/

# --- Python 虛擬環境與快取 ---
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/

# --- STM32CubeIDE / GCC 編譯產出與暫存檔 ---
# 編譯輸出資料夾
Debug/
Release/
# 中間編譯產物
*.o
*.d
*.su
*.cyclo
# 執行與燒錄二進位檔案
*.elf
*.map
*.hex
*.bin
*.list

# --- 報價單與清點工具 ---
checklist.html
# --- serial 監聽日誌（gui_monitor / 連續監聽輸出，動輒數 MB） ---
*.log

# --- KiCad 自動備份 ---
*_autosave*

# --- BOM 產出目錄 ---
bom/

# --- host 單元測試編譯產物（tests/Makefile BINS；萬用字元涵蓋現有與未來測試） ---
# 忽略所有 tests/test_* 執行檔，但保留同名 .c / .h 原始碼。
tests/test_*
!tests/test_*.c
!tests/test_*.h

# --- 本地自訂編譯路徑設定檔 ---
local.mk

# Makefile 自動產生的版本標頭與備份檔（每次建置更新，不納版控）
firmware/main_flight_code/Core/Inc/build_version.h
firmware/main_flight_code/Core/Inc/board_config.h.rolebak
