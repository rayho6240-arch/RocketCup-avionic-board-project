# ====================================================================
# RocketCup Avionic Board Project - Git Ignore Rules
# ====================================================================

# --- KiCad 核心忽略項目 (自動遞迴忽略所有目錄) ---
*.bak
*.bkp
*_backups/
*.tmp
*.lck
# Footprint 快取
fp-info-cache

# --- KiCad 6/7/8 備份與個人設定檔 ---
# 原理圖自動備份檔
*.kicad_sch-bak
# PCB版自動備份檔
*.kicad_pcb-bak
# 個人視窗設定與配置 (不傳版控以防不同螢幕配置衝突)
*.kicad_prl
# 個人偏好設定
*.kicad_user

# --- 輸出檔案 (通常不進版控，若要放 Gerber 可手動解除) ---
gbers/
plots/
*.net
*.xml
*.csv
*.gbr
*.drl

# --- 作業系統垃圾檔案 ---
# macOS Finder 配置檔 (全局遞迴忽略)
.DS_Store
# Windows 縮圖快取檔
Thumbs.db

# --- 編輯器與開發環境設定 ---
# VS Code 個人設定檔
.vscode/
# JetBrains 編輯器設定
.idea/
# Jupyter Notebook 快取
.ipynb_checkpoints/

# --- Python 虛擬環境與快取 ---
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/

# --- STM32CubeIDE / GCC 編譯產出與暫存檔 ---
# 編譯輸出資料夾
Debug/
Release/
# 中間編譯產物
*.o
*.d
*.su
*.cyclo
# 執行與燒錄二進位檔案
*.elf
*.map
*.hex
*.bin
*.list